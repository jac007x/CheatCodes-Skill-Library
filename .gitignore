# =============================================================================
# CheatCodes Skill Library — .gitignore
# Aligned to DOCTRINE.md: zero PII, zero signals, zero pre-universalized content
# =============================================================================

# --- Signal logs (belong in private repo only) ---
*.jsonl
**/session_signals.jsonl
**/library_health_latest.json
**/proposals/*.json
skill-improver/session_signals.jsonl
skill-improver/library_health_latest.json
skill-improver/proposals/

# --- Raw data files (never commit data) ---
*.csv
*.xlsx
*.xls
*.parquet
*.tsv
*.dat

# --- Session artifacts ---
session_*.md
*.session
session_log.*
.session_*

# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.venv/
venv/
env/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
Thumbs.db
ehthumbs.db
Desktop.ini
